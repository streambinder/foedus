{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "root": true,
  "files": {
    "includes": ["**", "!**/*.css"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "linter": {
    "rules": {
      "complexity": {
        "noImportantStyles": "off",
        "useArrowFunction": "off",
        "useOptionalChain": "off"
      },
      "style": {
        "useTemplate": "off",
        "noUselessElse": "off",
        "useConst": "off",
        "useExponentiationOperator": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noShadowRestrictedNames": "off",
        "noGlobalIsFinite": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noInnerDeclarations": "off",
        "noSelfAssign": "off",
        "noUnusedFunctionParameters": "off"
      }
    }
  }
}
